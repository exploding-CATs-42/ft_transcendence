generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  runtime             = "nodejs"
  moduleFormat        = "cjs"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED

  @@map("friendship_status")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(255)
  username     String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  avatarUrl    String?   @map("avatar_url") @db.Text
  isOnline     Boolean   @default(false) @map("is_online")
  lastSeenAt   DateTime? @map("last_seen_at")

  sessions           UserSession[]
  friendshipsAsLow   Friendship[]  @relation("FriendshipLowUser")
  friendshipsAsHigh  Friendship[]  @relation("FriendshipHighUser")
  friendshipRequests Friendship[]  @relation("FriendshipRequestedBy")
  wonGames           Game[]        @relation("GameWinner")
  gameMemberships    UserGame[]

  @@map("users")
}

model UserSession {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  refreshTokenHash String   @unique @map("refresh_token_hash") @db.VarChar(255)
  expiresAt        DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

model Friendship {
  id            String           @id @default(uuid()) @db.Uuid
  userLowId     String           @map("user_low_id") @db.Uuid
  userHighId    String           @map("user_high_id") @db.Uuid
  requestedById String           @map("requested_by_id") @db.Uuid
  status        FriendshipStatus

  userLow     User @relation("FriendshipLowUser", fields: [userLowId], references: [id], onDelete: Cascade)
  userHigh    User @relation("FriendshipHighUser", fields: [userHighId], references: [id], onDelete: Cascade)
  requestedBy User @relation("FriendshipRequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)

  @@unique([userLowId, userHighId])
  @@index([requestedById])
  @@map("friendships")
}

model Game {
  id           String    @id @default(uuid()) @db.Uuid
  gameName     String    @map("game_name") @db.VarChar(255)
  winnerUserId String?   @map("winner_user_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")
  startedAt    DateTime? @map("started_at")
  endedAt      DateTime? @map("ended_at")

  winner      User?      @relation("GameWinner", fields: [winnerUserId], references: [id], onDelete: SetNull)
  memberships UserGame[]

  @@index([winnerUserId])
  @@map("games")
}

model UserGame {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  gameId String @map("game_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId])
  @@map("users_games")
}

model Card {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique @db.VarChar(100)
  type        String  @db.VarChar(100)
  description String? @db.Text
  imageUrl    String? @map("image_url") @db.Text

  @@map("cards")
}
