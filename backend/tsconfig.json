{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    /* Compilation */
    "target": "es2024",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "./dist",

    /* Debugging */
    "sourceMap": true,

    "paths": {
      "types": ["./src/types/index"],
      "types/*": ["./src/types/*"],
      "lib": ["./src/lib/index"],
      "lib/*": ["./src/lib/*"],
      "schemas": ["./src/schemas/index"],
      "schemas/*": ["./src/schemas/*"],
      "services": ["./src/services/index"],
      "services/*": ["./src/services/*"],
      "utils": ["./src/utils/index"],
      "utils/*": ["./src/utils/*"],
      "errors": ["./src/errors/index"],
      "errors/*": ["./src/errors/*"],
      "game": ["./src/game/index"],
      "game/*": ["./src/game/*"],
      "constants": ["./src/constants/index"],
      "constants/*": ["./src/constants/*"],
      "middlewares": ["./src/middlewares/index"],
      "middlewares/*": ["./src/middlewares/*"],
      "controllers": ["./src/controllers/index"],
      "controllers/*": ["./src/controllers/*"],
      "data": ["./src/data/index"],
      "data/*": ["./src/data/*"],
      "sockets": ["./src/sockets/index"],
      "sockets/*": ["./src/sockets/*"],
      "mappers": ["./src/mappers/index"],
      "mappers/*": ["./src/mappers/*"],
      "generated/*": ["./src/generated/*"]
    }
  },
  "include": [
    "src",
    "tests",
    "eslint.config.ts",
    "vitest.config.ts",
    "prisma.config.ts"
  ],
  "exclude": ["**/*.visualized.ts"]
}
//You can see the full documentation on https://www.typescriptlang.org/tsconfig
