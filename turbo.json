{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    ".prettierrc",
    ".prettierignore",
    "tsconfig.*",
    "eslint.config.*"
  ],
  "tasks": {
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:check": {
      "dependsOn": ["^lint:check"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "format:check": {
      "dependsOn": ["^format:check"]
    }
  }
}
