{
  "name": "exploding-cats",
  "private": true,
  "scripts": {
    "format": "pnpm run -r --parallel format:check",
    "format:fix": "pnpm run -r --parallel format",
    "lint": "pnpm run -r --parallel lint:check",
    "lint:fix": "pnpm run -r --parallel lint",
    "typecheck": "pnpm run -r --parallel typecheck",
    "check": "pnpm run format && pnpm run lint && pnpm run typecheck",
    "fix": "pnpm run format:fix && pnpm run lint:fix"
  },
  "packageManager": "pnpm@10.33.0"
}
