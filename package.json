{
  "name": "exploding-cats-mono",
  "private": true,
  "scripts": {
    "format": "pnpm -r run format:check",
    "format:fix": "pnpm -r run format",
    "lint": "pnpm -r run lint:check",
    "lint:fix": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "check": "pnpm run format && pnpm run lint && pnpm run typecheck",
    "fix": "pnpm run format:fix && pnpm run lint:fix"
  },
  "packageManager": "pnpm@10.33.0"
}
