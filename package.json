{
  "name": "exploding-cats",
  "private": true,
  "scripts": {
    "format:check": "pnpm run -r --parallel format:check",
    "format:fix": "pnpm run -r --parallel format:fix",
    "lint:check": "pnpm run -r lint:check",
    "lint:fix": "pnpm run -r lint:fix",
    "typecheck": "pnpm run -r typecheck",
    "check": "pnpm run format:check && pnpm run lint:check && pnpm run typecheck",
    "fix": "pnpm run -r format:fix lint:fix",
    "dev": "make postgres && pnpm run -r dev"
  },
  "packageManager": "pnpm@10.33.0"
}
