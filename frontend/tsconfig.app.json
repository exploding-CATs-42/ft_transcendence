{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    // Aliases
    "paths": {
      "types": ["./src/web/@types/index"],
      "types/*": ["./src/web/@types/*"],
      "components": ["./src/web/components/index"],
      "components/*": ["./src/web/components/*"],
      "pages": ["./src/web/pages/index"],
      "pages/*": ["./src/web/pages/*"],
      "assets": ["./src/web/assets/index"],
      "assets/*": ["./src/web/assets/*"],
      "hooks": ["./src/web/hooks/index"],
      "hooks/*": ["./src/web/hooks/*"],
      "game": ["./src/game/index"],
      "game/*": ["./src/game/*"],
      "utils": ["./src/web/utils/index"],
      "utils/*": ["./src/web/utils/*"],
      "api": ["./src/web/api/index"],
      "api/*": ["./src/web/api/*"],
      "schemas": ["./src/web/schemas/index"],
      "schemas/*": ["./src/web/schemas/*"]
    }
  },
  "include": ["src"]
}
